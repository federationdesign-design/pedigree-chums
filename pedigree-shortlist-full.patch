+
+/* Mobile shortlist bar */
+@media (max-width: 768px) {
+  .label { display: none; }
+  .knockoutBtn { display: none; }
+  /* horizontal scroll instead of stacking */
+  .pills {
+    flex-wrap: nowrap;
+    overflow-x: auto;
+    overflow-y: hidden;
+    min-width: 0;
+    padding: 12px 8px 8px;
+    -webkit-overflow-scrolling: touch;
+  }
+  /* trash: out of the bar, top-right corner, larger, no circle */
+  .clearBtn {
+    position: absolute;
+    top: -46px;
+    right: 14px;
+    width: auto;
+    height: auto;
+    background: none;
+    border: none;
+    border-radius: 0;
+    padding: 4px;
+    color: #fff;
+    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.45));
+  }
+  .clearBtn:hover { background: none; }
+  .clearBtn svg { width: 34px; height: 34px; }
+}
